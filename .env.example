# ============================================================================
# AuraGrade Environment Variables - Example Template
# ============================================================================
# Copy this file to .env.local (frontend) and .env (backend)
# Replace all VALUES with your actual secrets from:
# - Supabase Dashboard (Settings > API)
# - Google Cloud Console (Gemini API credentials)
# - Production deployment environment
# ============================================================================

# ============================================================================
# FRONTEND (.env.local)
# ============================================================================

# Supabase Public Keys (safe for browser/client-side)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...  # From Supabase Settings > API > anon key

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000  # Dev: localhost | Prod: https://api.yourdomain.com

# Gemini API Key (for server-side rubric generation)
GEMINI_API_KEY=AIzaSy...  # From Google Cloud Console > Credentials

# ============================================================================
# MOBILE (.env or app.json > extra > apiUrl)
# ============================================================================

EXPO_PUBLIC_API_URL=http://localhost:8000  # Or your backend deployment URL

# ============================================================================
# BACKEND (backend/.env)
# ============================================================================

# Supabase Service Keys (NEVER expose to browser)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=eyJhbGc...  # From Supabase Settings > API > service_role key
SUPABASE_JWT_SECRET=super-secret-jwt-key-from-settings  # From Supabase > Settings > Database > JWT Secret

# Gemini API (for grading and rubric parsing)
GEMINI_API_KEY=AIzaSy...  # Same as frontend

# Pinecone (for RAG sync + Similarity Sentinel)
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=auragrade
# Backward-compatible alias used by existing backend code paths
PINECONE_INDEX=auragrade
# Optional, for legacy deployments/documentation
PINECONE_ENVIRONMENT=us-east-1-aws

# CORS Configuration (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AI_CALLS=10         # Max requests per window
RATE_LIMIT_WINDOW_SECONDS=60   # Window duration
RATE_LIMIT_STORAGE_URI=redis://localhost:6379  # Phase C: Production use

# ============================================================================
# DEPLOYMENT (Production .env)
# ============================================================================

# Same as backend above, but with:
# - SUPABASE_KEY = production service role key
# - CORS_ORIGIN = production domain only
# - RATE_LIMIT_STORAGE_URI = production Redis URL
